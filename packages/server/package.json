{
  "name": "ui5-cap-event-app-server",
  "version": "0.0.0",
  "description": "A simple CAP-based UI5 Event Application Server.",
  "private": true,
  "dependencies": {
    "@cap-js/sqlite": "2.4.0",
    "@sap/cds": "9.9.1",
    "express": "5.2.1",
    "passport": "0.7.0"
  },
  "devDependencies": {
    "@sap/cds-dk": "9.9.2",
    "cds-plugin-ui5": "0.17.3",
    "rimraf": "6.1.3",
    "ui5-cap-event-app-ui-admin": "*",
    "ui5-cap-event-app-ui-form": "*"
  },
  "scripts": {
    "clean": "rimraf gen",
    "build": "cds build",
    "watch": "cds watch",
    "start": "cds-serve"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": ":memory:"
        }
      }
    }
  }
}
